# Firebase Konfiguration
# Eigene Firebase-Projekt-Credentials hier eintragen.
# Anleitung: https://github.com/amgiparker/open-jf-coach/blob/main/FIREBASE_SETUP.md

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Eindeutige ID fuer dieses Team (wird als Firestore-Pfad verwendet)
# Beispiel: meine-jf-musterstadt
VITE_FIREBASE_TEAM_ID=
