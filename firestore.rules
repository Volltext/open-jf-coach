rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Nur authentifizierte Nutzer (auch anonym) dürfen den Team-State lesen/schreiben.
    // Jedes Team kann nur seinen eigenen Dokument-Pfad verwenden.
    match /teams/{teamId}/state/shared {
      allow read, write: if request.auth != null;
    }

    // Alle anderen Pfade sind gesperrt
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
